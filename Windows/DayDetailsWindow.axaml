<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FanShop.Windows.DayDetailsWindow"
        Width="900"
        Height="620"
        CanResize="False"
        SystemDecorations="None"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        Title="Детали дня">
    <Border Margin="18"
            Padding="18"
            Background="White"
            CornerRadius="16"
            BoxShadow="0 0 34 0 #40000000">
    <Grid RowDefinitions="Auto,*,Auto">
        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Информация о дне" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="{Binding Date, Converter={StaticResource RussianDateConverter}}" Foreground="#6E7E8F" />
            </StackPanel>
            <Button Grid.Column="1" Classes="ghost" Content="Закрыть" Click="CloseButton_Click" />
        </Grid>

        <Border Grid.Row="1" Background="#F9FBFD" BorderBrush="{StaticResource BrandBorder}" BorderThickness="1" CornerRadius="12" Padding="12">
            <DataGrid ItemsSource="{Binding Employees}"
                      SelectedItem="{Binding SelectedEmployee}"
                      AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Фамилия" Binding="{Binding Surname}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="Дата рождения" Binding="{Binding DateOfBirth}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="Занятость" Binding="{Binding WorkDuration}" Width="*" IsReadOnly="True" />
                    <DataGridCheckBoxColumn Header="В пропуск" Binding="{Binding IncludeInPass}" Width="110" />
                    <DataGridCheckBoxColumn Header="В зарплату" Binding="{Binding IncludeInSalary}" Width="110" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" Margin="0,12,0,0">
            <Button Content="Добавить" Command="{Binding AddEmployeesCommand}" />
            <Button Classes="danger" Content="Удалить" Command="{Binding RemoveEmployeesCommand}" />
            <Button Content="Пропуск" Command="{Binding PrintPassCommand}" />
            <Button Content="Тайминг" Command="{Binding DailyScheduleCommand}" />
            <Button Classes="ghost" Content="Закрыть" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
    </Border>
</Window>
