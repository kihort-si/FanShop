<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FanShop.Windows.DayTasksWindow"
        Width="1100"
        Height="680"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Title="Тайминг дня">
    <Grid RowDefinitions="Auto,*,Auto" Margin="18">
        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="График задач" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="{Binding Date, Converter={StaticResource RussianDateConverter}}" Foreground="#6E7E8F" />
            </StackPanel>
            <Button Grid.Column="1" Content="Закрыть" Click="CloseButton_Click" />
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="1.2*,0.8*">
            <Border Background="#F9FBFD" BorderBrush="#D7E4EF" BorderThickness="1" CornerRadius="12" Padding="12">
                <DataGrid ItemsSource="{Binding DayTasks}"
                          SelectedItem="{Binding SelectedTask}"
                          AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Начало" Binding="{Binding StartTimeText}" Width="90" />
                        <DataGridTextColumn Header="Конец" Binding="{Binding EndTimeText}" Width="90" />
                        <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="2*" />
                        <DataGridTextColumn Header="Описание" Binding="{Binding Comment}" Width="2*" />
                        <DataGridTextColumn Header="Категория" Binding="{Binding Category.Name}" Width="*" />
                        <DataGridTextColumn Header="Длительность" Binding="{Binding Duration, Converter={StaticResource TimeSpanFormatConverter}}" Width="*" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Margin="12,0,0,0" Background="#F9FBFD" BorderBrush="#D7E4EF" BorderThickness="1" CornerRadius="12" Padding="12">
                <StackPanel Spacing="10">
                    <TextBlock Text="Редактор задачи" FontSize="18" FontWeight="Bold" />
                    <TextBox Watermark="Название" Text="{Binding SelectedTask.Title}" />
                    <TextBox Watermark="Описание" Text="{Binding SelectedTask.Comment}" AcceptsReturn="True" Height="100" />
                    <Grid ColumnDefinitions="*,*">
                        <TextBox Grid.Column="0" Watermark="Начало" Text="{Binding SelectedTask.StartTimeText}" />
                        <TextBox Grid.Column="1" Margin="8,0,0,0" Watermark="Конец" Text="{Binding SelectedTask.EndTimeText}" />
                    </Grid>
                    <ComboBox ItemsSource="{Binding TaskCategories}"
                              SelectedItem="{Binding SelectedTask.Category}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="Сохранить изменения" Command="{Binding SaveSelectedTaskCommand}" />
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Добавить" Command="{Binding AddTaskCommand}" />
            <Button Content="Удалить" Command="{Binding RemoveTaskCommand}" />
            <Button Content="Экспорт Excel" Command="{Binding ExportToExcelCommand}" />
            <Button Content="Закрыть" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
