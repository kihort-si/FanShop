<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FanShop.Windows.DayTasksWindow"
        Width="1100"
        Height="680"
        CanResize="False"
        SystemDecorations="None"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        Title="Тайминг дня">
    <Border Margin="18"
            Padding="18"
            Background="White"
            CornerRadius="16"
            BoxShadow="0 0 34 0 #40000000">
    <Grid RowDefinitions="Auto,*,Auto">
        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="График задач" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="{Binding Date, Converter={StaticResource RussianDateConverter}}" Foreground="#6E7E8F" />
            </StackPanel>
            <Button Grid.Column="1" Classes="ghost" Content="Закрыть" Click="CloseButton_Click" />
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="1.2*,0.8*">
            <Border Background="#F9FBFD" BorderBrush="{StaticResource BrandBorder}" BorderThickness="1" CornerRadius="12" Padding="12">
                <DataGrid ItemsSource="{Binding DayTasks}"
                          SelectedItem="{Binding SelectedTask}"
                          AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Начало" Binding="{Binding StartTimeText}" Width="50" IsReadOnly="True" />
                        <DataGridTextColumn Header="Конец" Binding="{Binding EndTimeText}" Width="50" IsReadOnly="True" />
                        <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="90" IsReadOnly="True" />
                        <DataGridTextColumn Header="Описание" Binding="{Binding Comment}" Width="90" IsReadOnly="True" />
                        <DataGridTextColumn Header="Категория" Binding="{Binding Category.Name}" Width="*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Длительность" Binding="{Binding Duration, Converter={StaticResource TimeSpanFormatConverter}}" Width="*" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1"
                    Margin="12,0,0,0"
                    Background="#F9FBFD"
                    BorderBrush="{StaticResource BrandBorder}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20"
                    IsVisible="{Binding !HasTasks}">
                
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">

                    <TextBlock
                        Text="На этот день пока нет задач"
                        FontSize="22"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"/>

                    <TextBlock
                        Text="Создайте первую задачу для этого дня."
                        Foreground="Gray"
                        HorizontalAlignment="Center"/>

                    <Button
                        Content="Добавить задачу"
                        Command="{Binding AddTaskCommand}"
                        HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <Border Grid.Column="1"
                    Margin="12,0,0,0"
                    Background="#F9FBFD"
                    BorderBrush="{StaticResource BrandBorder}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20"
                    IsVisible="{Binding HasTasks}">
                <Grid>
                    <StackPanel
                        IsVisible="{Binding !HasSelectedTask}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                        <TextBlock
                            Text="Выберите задачу"
                            FontSize="20"
                            FontWeight="Bold"/>

                        <TextBlock
                            Text="Для просмотра и редактирования"
                            Foreground="Gray"/>

                    </StackPanel>

                    <StackPanel
                        IsVisible="{Binding HasSelectedTask}"
                        Spacing="10">
                        <TextBlock Text="Редактор задачи" FontSize="18" FontWeight="Bold" />
                        <TextBox Watermark="Название" Text="{Binding SelectedTask.Title}" />
                        <TextBox Watermark="Описание" Text="{Binding SelectedTask.Comment}" AcceptsReturn="True" Height="100" />
                        <Grid ColumnDefinitions="*,Auto,*,Auto">
                            <TextBox Grid.Column="0" Watermark="Начало" Text="{Binding SelectedTask.StartTimeText}" />
                            <Button Grid.Column="1" Content="Сейчас" Command="{Binding SetStartNowCommand}" Margin="8, 0, 0, 0"/>
                            <TextBox Grid.Column="2" Margin="8,0,0,0" Watermark="Конец" Text="{Binding SelectedTask.EndTimeText}" />
                            <Button Grid.Column="3" Content="Сейчас" Command="{Binding SetEndNowCommand}" Margin="8, 0, 0, 0"/>
                        </Grid>
                        <ComboBox ItemsSource="{Binding TaskCategories}"
                                  SelectedItem="{Binding SelectedTask.Category}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="Сохранить изменения" Command="{Binding SaveSelectedTaskCommand}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Добавить" Command="{Binding AddTaskCommand}" />
            <Button Classes="danger" Content="Удалить" Command="{Binding RemoveTaskCommand}" />
            <Button Content="Экспорт Excel" Command="{Binding ExportToExcelCommand}" />
            <Button Classes="ghost" Content="Закрыть" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
    </Border>
</Window>
