<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FanShop.View.EditEmployeeControl">
    <ScrollViewer>
        <StackPanel Margin="24" Spacing="12" MaxWidth="720">
            <TextBlock Text="Карточка сотрудника" FontSize="24" FontWeight="Bold" />
            <TextBox Watermark="Фамилия" Text="{Binding Surname}" />
            <TextBox Watermark="Имя" Text="{Binding FirstName}" />
            <TextBox Watermark="Отчество" Text="{Binding LastName}" />
            <TextBox Watermark="Дата рождения" Text="{Binding DateOfBirth}" />
            <TextBox Watermark="Место рождения" Text="{Binding PlaceOfBirth}" />
            <TextBox Watermark="Паспорт" Text="{Binding Passport}" />
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                <Button Content="Сохранить" Command="{Binding SaveEditedEmployeeCommand}" />
                <Button Content="Отмена" Command="{Binding CancelCommand}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
