<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FanShop.View.TaskCategoriesControl">
    <Grid RowDefinitions="Auto,*" Margin="20">
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
            <Button Content="Добавить" Command="{Binding AddCategoryCommand}" />
            <Button Content="Изменить" Command="{Binding EditCategoryCommand}" />
            <Button Classes="danger" Content="Удалить" Command="{Binding RemoveCategoryCommand}" />
            <Button Content="Аналитика" Command="{Binding OpenAnalyticsCommand}" />
        </StackPanel>

        <Border Grid.Row="1" Background="#F9FBFD" BorderBrush="#D7E4EF" BorderThickness="1" CornerRadius="12" Padding="12">
            <DataGrid ItemsSource="{Binding TaskCategories}"
                      SelectedItem="{Binding SelectedCategory}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="2*" />
                    <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="3*" />
                    <DataGridTemplateColumn Header="Цвет" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Color}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Задача по умолчанию" Binding="{Binding DefaultTask}" Width="2*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
