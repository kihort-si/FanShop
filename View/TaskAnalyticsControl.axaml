<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="FanShop.View.TaskAnalyticsControl">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20" Spacing="16">
            <Grid ColumnDefinitions="*,Auto">

                <StackPanel>
                    <TextBlock Text="Аналитика задач"
                               FontSize="28"
                               FontWeight="Bold"/>

                    <TextBlock Text="Статистика выполнения задач, распределение времени и анализ переключений"
                               Foreground="#6E7E8F"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Classes="ghost"
                        Content="Закрыть"
                        Command="{Binding CloseCommand}"/>

            </Grid>

            <Border Background="#F9FBFD"
                    BorderBrush="#D7E4EF"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12">
                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*">

                    <DatePicker SelectedDate="{Binding StartDateSelection}" />

                    <DatePicker Grid.Column="1"
                                Margin="8,0,0,0"
                                SelectedDate="{Binding EndDateSelection}" />

                    <Button Grid.Column="2"
                            Margin="8,0,0,0"
                            Content="Обновить"
                            Command="{Binding UpdateAnalyticsCommand}"/>

                    <Button Grid.Column="3"
                            Margin="8,0,0,0"
                            Classes="excel"
                            Content="Экспорт Excel"
                            Command="{Binding ExportToExcelCommand}"/>
                </Grid>
            </Border>
            
            <ItemsControl ItemsSource="{Binding StatisticItems}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>

                    <DataTemplate>

                        <Border Width="250"
                                Margin="6"
                                Padding="14"
                                Background="#F9FBFD"
                                BorderBrush="#D7E4EF"
                                BorderThickness="1"
                                CornerRadius="12">

                            <StackPanel>

                                <TextBlock Text="{Binding Value}"
                                           FontWeight="Bold"
                                           FontSize="22"/>

                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding Label}"
                                           Foreground="#6E7E8F"
                                           TextWrapping="Wrap"/>

                            </StackPanel>

                        </Border>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>

            <StackPanel Spacing="16">

                <Border Height="360">
                    <StackPanel>
                        <TextBlock Text="Распределение времени по категориям"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,12"/>
                        <lvc:PieChart
                            Height="300"
                            Series="{Binding CategorySeries}"
                            LegendPosition="Right"/>
                    </StackPanel>
                </Border>

                <Border Height="360">
                    <StackPanel>
                        <TextBlock Text="Нагрузка по дням недели"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,12"/>
                        <lvc:CartesianChart
                            Height="300"
                            Series="{Binding DayOfWeekSeries}"
                            XAxes="{Binding DayOfWeekXAxes}"/>
                    </StackPanel>
                </Border>

                <Border Height="360">
                    <StackPanel>
                        <TextBlock Text="Распределение рабочего времени по часам"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,12"/>
                        <lvc:CartesianChart
                            Height="300"
                            Series="{Binding HourOfDaySeries}"
                            XAxes="{Binding HourOfDayXAxes}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
            
            <Border Background="#F9FBFD"
                    BorderBrush="#D7E4EF"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12">

                <StackPanel Spacing="12">

                    <TextBlock Text="Анализ переключений между категориями"
                               FontSize="18"
                               FontWeight="Bold"/>

                    <TextBlock Text="Показывает, какие категории чаще всего следуют сразу после выбранной."
                               Foreground="#6E7E8F"/>

                    <ComboBox Width="320"
                              ItemsSource="{Binding AvailableCategories}"
                              SelectedItem="{Binding SelectedCategoryForInterruptions}">

                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">

                                    <Border Width="14"
                                            Height="14"
                                            CornerRadius="3"
                                            Background="{Binding Color}"/>

                                    <TextBlock Text="{Binding Name}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <ItemsControl ItemsSource="{Binding Interruptions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="260"
                                        Margin="6"
                                        Padding="12"
                                        Background="White"
                                        BorderBrush="#D7E4EF"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <Border Width="16"
                                                    Height="16"
                                                    CornerRadius="3"
                                                    Background="{Binding CategoryColor}"/>

                                            <TextBlock Text="{Binding CategoryName}"
                                                       FontWeight="Bold"/>
                                        </StackPanel>

                                        <Separator Margin="0,8"/>

                                        <Grid ColumnDefinitions="*,Auto">

                                            <TextBlock Text="Количество переключений"/>

                                            <TextBlock Grid.Column="1"
                                                       FontWeight="Bold"
                                                       FontSize="20"
                                                       Text="{Binding Count}"/>
                                        </Grid>

                                        <Grid Margin="0,8,0,0"
                                              ColumnDefinitions="*,Auto">

                                            <TextBlock Text="Среднее время"/>

                                            <TextBlock Grid.Column="1"
                                                       Foreground="#0A6DAE"
                                                       FontWeight="Bold"
                                                       Text="{Binding FormattedAverage}"/>

                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>