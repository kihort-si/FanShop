<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FanShop.View.SettingsControl">
    <ScrollViewer>
        <StackPanel Margin="24" Spacing="12" MaxWidth="760">
            <TextBlock Text="Настройки" FontSize="24" FontWeight="Bold" />
            <TextBox Watermark="Руководитель" Text="{Binding Head}" />
            <TextBox Watermark="Ответственный" Text="{Binding ResponsiblePerson}" />
            <TextBox Watermark="Телефон" Text="{Binding ResponsiblePhoneNumber}" />
            <TextBox Watermark="Должность" Text="{Binding ResponsiblePosition}" />
            <TextBox Watermark="Цель визита" Text="{Binding VisitGoal}" />
            <NumericUpDown Minimum="0" Maximum="100000" Increment="500" Value="{Binding DailySalary}" FormatString="F0" />
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                <Button Content="Сохранить" Command="{Binding SaveCommand}" />
                <Button Content="Отмена" Command="{Binding CancelCommand}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
